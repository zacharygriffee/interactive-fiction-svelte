{
  "name": "interactive-fiction-svelte",
  "version": "0.6.0",
  "type": "module",
  "main": "index.html",
  "exports": {
    ".": "./src/lib/index.js",
    "./package.json": "./package.json",
    "./examples": "./examples/index.js"
  },
  "license": "MIT",
  "scripts": {
    "build": "rollup -c && npm run prepare-dist:play",
    "dev": "node scripts/dev.js",
    "dev:watch": "rollup -c -w",
    "dev:serve": "sirv dist --dev --single --host 0.0.0.0 --port 4173",
    "prepare-dist:dev": "node scripts/prepare-dist.js dev",
    "prepare-dist:play": "node scripts/prepare-dist.js play",
    "start": "node scripts/start.js",
    "run-if": "node scripts/if-run.js",
    "validate-graph": "node scripts/validate-graph.js",
    "validate-graph:all": "node scripts/validate-graph-all.js",
    "validate-assets": "node scripts/validate-assets.js",
    "watch-build": "nodemon --watch src --ext js,svelte --exec 'npm run build'",
    "test": "brittle test/*.test.js",
    "test:smoke": "playwright test --config=playwright.config.js",
    "test:browser": "playwright test --config=playwright.browser.config.js",
    "test:ci": "npm run validate-graph:all && npm run validate-assets && npm test && npm run build && npm run test:smoke",
    "test:full": "npm run validate-graph:all && npm run validate-assets && npm test && npm run build && npm run test:smoke && npm run test:browser",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@rollup/plugin-alias": "^5.1.1",
    "@rollup/plugin-commonjs": "^28.0.2",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "brittle": "^3.0.0",
    "nodemon": "^3.1.9",
    "rollup": "^4.30.1",
    "rollup-plugin-svelte": "^7.2.2",
    "sirv-cli": "^3.0.1",
    "svelte": "^5.18.0"
  }
}
